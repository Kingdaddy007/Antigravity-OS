{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://antigravity-os.dev/schemas/manifest.schema.json",
  "title": "Anti-Gravity OS manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "os_version",
    "canonical",
    "hosts",
    "profiles",
    "mutation_classes",
    "skills",
    "workflows",
    "context_templates",
    "baselines",
    "templates"
  ],
  "properties": {
    "schema_version": { "const": 1 },
    "os_version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "canonical": { "type": "object" },
    "hosts": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string" } },
    "profiles": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string" } },
    "mutation_classes": { "type": "array", "minItems": 5, "uniqueItems": true, "items": { "type": "string" } },
    "skills": { "$ref": "#/$defs/registry" },
    "workflows": { "$ref": "#/$defs/registry" },
    "context_templates": { "$ref": "#/$defs/registry" },
    "baselines": { "$ref": "#/$defs/registry" },
    "templates": { "$ref": "#/$defs/registry" }
  },
  "$defs": {
    "registry": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "path", "profiles"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
          "path": { "type": "string", "minLength": 1 },
          "profiles": { "type": "array", "minItems": 1, "items": { "type": "string" } }
        }
      }
    }
  }
}

